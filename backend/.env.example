# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → copy connection string
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net
MONGO_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net

# Database name (any name — will be auto-created)
DB_NAME=trade_os

# Comma-separated list of allowed frontend origins (NO trailing slash)
# Add your Vercel URL here once deployed
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
