# Backend URL where your FastAPI server is hosted
# Example: https://trade-os-api.railway.app or https://your-backend.onrender.com
REACT_APP_BACKEND_URL=https://YOUR-BACKEND-URL.com

# Required by Webpack dev server (don't change in production)
WDS_SOCKET_PORT=443

# Optional — disables Emergent health check (keep false for Vercel)
ENABLE_HEALTH_CHECK=false
